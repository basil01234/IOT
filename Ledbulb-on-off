#include <ESP8266WiFi.h>
#include <Espalexa.h>

const char* ssid = "YOUR_WIFI_NAME";
const char* password = "YOUR_WIFI_PASSWORD";

#define RELAY_PIN 5   // D1 = GPIO5

Espalexa espalexa;

void lightChanged(uint8_t brightness) {
  Serial.print("Brightness: ");
  Serial.println(brightness);

  if (brightness > 0) {
    digitalWrite(RELAY_PIN, LOW);   // ON (active LOW relay)
    Serial.println("Light ON");
  } else {
    digitalWrite(RELAY_PIN, HIGH);  // OFF
    Serial.println("Light OFF");
  }
}

void setup() {
  Serial.begin(115200);

  pinMode(RELAY_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, HIGH); // Start OFF

  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);

  Serial.print("Connecting");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nConnected");
  Serial.println(WiFi.localIP());

  espalexa.addDevice("Light", lightChanged);
  espalexa.begin();

  Serial.println("Alexa Ready");
}

void loop() {
  espalexa.loop();
}
